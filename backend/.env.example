PORT=5000
MONGO_URI=mongodb://localhost:27017/stocksignals

# Admin credentials (auto-created on first run)
ADMIN_EMAIL=admin@yourstockai.com
ADMIN_PASSWORD=Admin@123

# JWT
JWT_SECRET=yourstockai_super_secret_jwt_key_change_this

# Frontend base URL for password reset links
FRONTEND_URL=http://localhost:3000

# Alpha Vantage (real-time prices)
ALPHA_VANTAGE_KEY=your_key_here

# Email alerts 
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
ALERT_FROM=your@gmail.com


